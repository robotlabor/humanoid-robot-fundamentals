<mujoco model="three_link_throw">
  <compiler angle="radian" coordinate="local"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <joint damping="0.05" armature="0.01" limited="true"/>
    <geom density="800" friction="0.8 0.1 0.1"/>
    <motor ctrllimited="true"/>
  </default>

  <asset>
    <material name="arm_mat" rgba="0.2 0.4 0.8 1"/>
    <material name="ball_mat" rgba="0.9 0.2 0.1 1"/>
    <material name="target_mat" rgba="0.1 0.8 0.2 0.45"/>
    <material name="ground_mat" rgba="0.65 0.65 0.65 1"/>
  </asset>

  <worldbody>
    <light pos="0 -3 5" dir="0 1 -1"/>
    <camera name="side" pos="1.6 -4.5 1.2" xyaxes="1 0 0 0 0 1"/>
    <geom name="ground" type="plane" size="6 6 0.1" material="ground_mat"/>

    <body name="base" pos="0 0 0.75">
      <geom type="sphere" size="0.04" rgba="0.1 0.1 0.1 1"/>
      <body name="link1" pos="0 0 0">
        <joint name="shoulder" type="hinge" axis="0 1 0" range="-2.8 2.8"/>
        <geom name="upper_arm" type="capsule" fromto="0 0 0 0.38 0 0" size="0.035" material="arm_mat"/>
        <body name="link2" pos="0.38 0 0">
          <joint name="elbow" type="hinge" axis="0 1 0" range="-2.8 2.8"/>
          <geom name="forearm" type="capsule" fromto="0 0 0 0.32 0 0" size="0.03" material="arm_mat"/>
          <body name="link3" pos="0.32 0 0">
            <joint name="wrist" type="hinge" axis="0 1 0" range="-2.8 2.8"/>
            <geom name="hand_link" type="capsule" fromto="0 0 0 0.20 0 0" size="0.025" material="arm_mat"/>
            <site name="hand_site" pos="0.22 0 0" size="0.025" rgba="1 1 0 1"/>
          </body>
        </body>
      </body>
    </body>

    <body name="ball" pos="0.97 0 0.75">
      <freejoint name="ball_free"/>
      <geom name="ball_geom" type="sphere" size="0.045" mass="0.08" material="ball_mat"/>
    </body>

    <body name="target" pos="2.0 0 0.65">
      <geom name="target_geom" type="sphere" size="0.08" contype="0" conaffinity="0" material="target_mat"/>
    </body>
  </worldbody>

  <equality>
    <weld name="hold_ball" body1="link3" body2="ball" active="true"
          relpose="0.27 0 0 1 0 0 0" solref="0.002 1" solimp="0.95 0.99 0.001"/>
  </equality>

  <actuator>
    <position name="shoulder_pos" joint="shoulder" kp="35" ctrlrange="-2.8 2.8"/>
    <position name="elbow_pos" joint="elbow" kp="30" ctrlrange="-2.8 2.8"/>
    <position name="wrist_pos" joint="wrist" kp="20" ctrlrange="-2.8 2.8"/>
  </actuator>
</mujoco>
